<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#006600"
    android:clipChildren="false"
    tools:context=".GamePage">

    <!-- RIGHT ORGANIZE AREA -->
    <!-- This is a simple ViewGroup to hold the right-side piles -->
    <FrameLayout
        android:id="@+id/organizeArea"
        android:layout_width="@dimen/margin_organize_area"
        android:layout_height="0dp"
        android:background="#004400"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- LEFT PLAY AREA -->
    <!-- This ViewGroup holds the main playing piles -->
    <FrameLayout
        android:id="@+id/playArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/organizeArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
